# Database connection
DATABASE_URL=postgresql://user:password@localhost:5432/ycode

# Admin password for the builder (leave empty to disable login)
ADMIN_PASSWORD=

# Secret key for signing auth cookies (generate with: openssl rand -hex 32)
PAGE_AUTH_SECRET=

# Upload directory for assets (defaults to ./uploads)
UPLOAD_DIR=./uploads

# Templates API (optional)
NEXT_PUBLIC_TEMPLATE_API_URL=
TEMPLATE_API_URL=
TEMPLATE_UPLOAD_API_KEY=

# Google Fonts API Key (only used to execute `npm run fonts:update`)
GOOGLE_FONTS_API_KEY=
